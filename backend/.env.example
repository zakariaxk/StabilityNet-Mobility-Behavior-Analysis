# Local backend service settings.
#
# Values can be exported in your shell before starting uvicorn.

# Comma-separated frontend origins allowed by CORS.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# Optional single-origin alternative if ALLOWED_ORIGINS is not set.
FRONTEND_ORIGIN=http://localhost:3000

# Local YOLO weights file. Relative paths are resolved from the backend folder.
# Default expected path: backend/yolo26n.pt
# Use an absolute path if you keep weights somewhere else.
STABILITYNET_DETECTOR_MODEL=yolo26n.pt

# CPU-first by default. Set to auto, mps, cuda, cuda:0, or a CUDA index only
# when you intentionally want PyTorch to use an accelerator.
STABILITYNET_DETECTOR_DEVICE=cpu
